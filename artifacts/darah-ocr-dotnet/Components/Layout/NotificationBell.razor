@rendermode InteractiveServer
@inject AppDbContext Db
@inject IHttpContextAccessor HttpCtx
@inject JobProgressService ProgressService
@implements IAsyncDisposable

<div class="dropdown">
    <button class="btn btn-sm btn-outline-secondary position-relative" type="button"
            data-bs-toggle="dropdown" @onclick="MarkAllRead">
        <i class="bi bi-bell fs-5"></i>
        @if (_unreadCount > 0)
        {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                @(_unreadCount > 9 ? "9+" : _unreadCount.ToString())
            </span>
        }
    </button>
    <div class="dropdown-menu dropdown-menu-start p-0" style="min-width:320px; max-height:400px; overflow-y:auto;">
        <div class="p-2 border-bottom d-flex justify-content-between align-items-center">
            <strong class="small">الإشعارات</strong>
            @if (_unreadCount > 0)
            {
                <span class="badge bg-primary">@_unreadCount جديد</span>
            }
        </div>
        @if (!_notifications.Any())
        {
            <div class="p-3 text-center text-muted small">لا توجد إشعارات</div>
        }
        else
        {
            @foreach (var n in _notifications)
            {
                <a href="/jobs/@n.JobId" class="dropdown-item py-2 border-bottom @(n.IsRead ? "" : "bg-light")">
                    <div class="d-flex align-items-start gap-2">
                        <i class="bi @n.Icon text-@n.Color mt-1"></i>
                        <div>
                            <div class="small fw-semibold">@n.Title</div>
                            <div class="text-muted" style="font-size:0.75rem;">@n.Body</div>
                            <div class="text-muted" style="font-size:0.7rem;">@n.Time.ToString("HH:mm - dd/MM/yyyy")</div>
                        </div>
                    </div>
                </a>
            }
        }
    </div>
</div>

@code {
    private List<NotifItem> _notifications = [];
    private int _unreadCount = 0;
    private IAsyncDisposable? _subscription;
    private int _userId;

    protected override async Task OnInitializedAsync()
    {
        _userId = int.TryParse(HttpCtx.HttpContext?.Session.GetString("userId"), out var uid) ? uid : 0;
        await LoadNotificationsAsync();

        _subscription = await ProgressService.SubscribeAsync(async evt =>
        {
            if (evt.Status is "ocr_complete" or "reviewed")
            {
                await LoadNotificationsAsync();
                await InvokeAsync(StateHasChanged);
            }
        }, _userId);
    }

    private async Task LoadNotificationsAsync()
    {
        var role = HttpCtx.HttpContext?.Session.GetString("role") ?? "";
        var now = DateTime.UtcNow;

        var jobs = await Db.Jobs
            .Include(j => j.User)
            .OrderByDescending(j => j.UpdatedAt)
            .Take(20)
            .ToListAsync();

        var notifs = new List<NotifItem>();

        foreach (var j in jobs)
        {
            if (j.Status == "ocr_complete" && (role == "admin" || role == "reviewer"))
            {
                notifs.Add(new NotifItem(j.Id, "bi-eye", "primary",
                    "وثيقة جاهزة للمراجعة",
                    $"{j.OriginalFilename} — اكتملت معالجة OCR",
                    j.UpdatedAt, j.UpdatedAt > now.AddHours(-1)));
            }
            if (j.Status == "reviewed" && (role == "admin" || role == "approver"))
            {
                notifs.Add(new NotifItem(j.Id, "bi-check2-circle", "success",
                    "وثيقة في انتظار الاعتماد",
                    $"{j.OriginalFilename} — تمت مراجعتها",
                    j.UpdatedAt, j.UpdatedAt > now.AddHours(-1)));
            }
        }

        _notifications = notifs.OrderByDescending(n => n.Time).Take(10).ToList();
        _unreadCount = _notifications.Count(n => !n.IsRead);
    }

    private void MarkAllRead()
    {
        foreach (var n in _notifications) n.IsRead = true;
        _unreadCount = 0;
    }

    public async ValueTask DisposeAsync()
    {
        if (_subscription != null)
            await _subscription.DisposeAsync();
    }

    record NotifItem(int JobId, string Icon, string Color, string Title, string Body, DateTime Time, bool IsNew)
    {
        public bool IsRead { get; set; } = !IsNew;
    }
}
