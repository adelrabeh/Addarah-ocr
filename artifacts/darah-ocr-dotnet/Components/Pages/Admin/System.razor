@page "/admin/system"
@rendermode InteractiveServer
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpCtx

<PageTitle>إحصائيات الأداء</PageTitle>

@if (!_authenticated) { return; }

<h5 class="mb-4"><i class="bi bi-graph-up me-2"></i>إحصائيات الأداء</h5>

<!-- System overview -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card" style="border-right:4px solid #0d6efd;">
            <div class="stat-icon bg-primary-subtle text-primary"><i class="bi bi-files fs-3"></i></div>
            <div><div class="stat-value">@_sysStat.TotalJobs</div><div class="stat-label">إجمالي الوثائق</div></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card" style="border-right:4px solid #198754;">
            <div class="stat-icon bg-success-subtle text-success"><i class="bi bi-check-all fs-3"></i></div>
            <div><div class="stat-value">@_sysStat.ApprovedJobs</div><div class="stat-label">معتمدة</div></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card" style="border-right:4px solid #6f42c1;">
            <div class="stat-icon" style="background:#f3efff; color:#6f42c1;"><i class="bi bi-clock-history fs-3"></i></div>
            <div><div class="stat-value">@_sysStat.AvgDuration</div><div class="stat-label">متوسط وقت المعالجة</div></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card" style="border-right:4px solid #fd7e14;">
            <div class="stat-icon bg-warning-subtle text-warning"><i class="bi bi-person-check fs-3"></i></div>
            <div><div class="stat-value">@_sysStat.ActiveUsers</div><div class="stat-label">مستخدمون نشطون</div></div>
        </div>
    </div>
</div>

<!-- Per-user stats -->
<div class="card shadow-sm">
    <div class="card-header"><h6 class="mb-0"><i class="bi bi-people me-2"></i>أداء المستخدمين</h6></div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>المستخدم</th><th>الدور</th><th>وثائق مرفوعة</th>
                    <th>وثائق راجعها</th><th>وثائق اعتمدها</th>
                    <th>متوسط وقت المعالجة</th><th>متوسط الثقة</th>
                </tr>
            </thead>
            <tbody>
                @if (_loading)
                {
                    <tr><td colspan="7" class="text-center py-4"><span class="spinner-border spinner-border-sm"></span></td></tr>
                }
                @foreach (var u in _userStats)
                {
                    <tr>
                        <td><i class="bi bi-person-circle me-1 text-primary"></i>@u.Username</td>
                        <td><span class="badge @(u.Role == "admin" ? "bg-danger" : "bg-secondary")">@u.Role</span></td>
                        <td class="text-center"><span class="badge bg-primary rounded-pill">@u.Uploaded</span></td>
                        <td class="text-center"><span class="badge bg-info text-dark rounded-pill">@u.Reviewed</span></td>
                        <td class="text-center"><span class="badge bg-success rounded-pill">@u.Approved</span></td>
                        <td class="text-muted small">@u.AvgDuration</td>
                        <td>
                            @if (u.AvgConfidence > 0)
                            {
                                <span class="badge @(u.AvgConfidence >= 85 ? "bg-success" : u.AvgConfidence >= 65 ? "bg-warning text-dark" : "bg-danger")">
                                    @u.AvgConfidence%
                                </span>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private bool _authenticated;
    private bool _loading = true;
    private SystemStat _sysStat = new();
    private List<UserStat> _userStats = [];

    protected override async Task OnInitializedAsync()
    {
        var role = HttpCtx.HttpContext?.Session.GetString("role");
        if (role != "admin") { Nav.NavigateTo("/", true); return; }
        _authenticated = true;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _sysStat.TotalJobs = await Db.Jobs.CountAsync();
        _sysStat.ApprovedJobs = await Db.Jobs.CountAsync(j => j.Status == "approved");
        _sysStat.ActiveUsers = await Db.Users.CountAsync(u => u.IsActive);

        var avgMs = await Db.Jobs
            .Where(j => j.ProcessingDurationMs.HasValue)
            .AverageAsync(j => (double?)j.ProcessingDurationMs) ?? 0;
        _sysStat.AvgDuration = avgMs > 0 ? $"{avgMs / 60000:F1} دقيقة" : "—";

        var users = await Db.Users.ToListAsync();

        _userStats = (await Task.WhenAll(users.Select(async u =>
        {
            var uploaded = await Db.Jobs.CountAsync(j => j.UserId == u.Id);
            var reviewed = await Db.Jobs.CountAsync(j => j.ReviewerId == u.Id);
            var approved = await Db.Jobs.CountAsync(j => j.ApproverId == u.Id);

            var avgMs2 = await Db.Jobs
                .Where(j => j.UserId == u.Id && j.ProcessingDurationMs.HasValue)
                .AverageAsync(j => (double?)j.ProcessingDurationMs) ?? 0;

            var avgConf = await Db.OcrResults
                .Include(r => r.Job)
                .Where(r => r.Job != null && r.Job.UserId == u.Id)
                .AverageAsync(r => (double?)r.ConfidenceScore) ?? 0;

            return new UserStat
            {
                Username = u.Username,
                Role = u.Role,
                Uploaded = uploaded,
                Reviewed = reviewed,
                Approved = approved,
                AvgDuration = avgMs2 > 0 ? $"{avgMs2 / 60000:F1} دقيقة" : "—",
                AvgConfidence = Math.Round(avgConf, 1)
            };
        }))).ToList();

        _loading = false;
    }

    class SystemStat
    {
        public int TotalJobs { get; set; }
        public int ApprovedJobs { get; set; }
        public int ActiveUsers { get; set; }
        public string AvgDuration { get; set; } = "—";
    }

    class UserStat
    {
        public string Username { get; set; } = "";
        public string Role { get; set; } = "";
        public int Uploaded { get; set; }
        public int Reviewed { get; set; }
        public int Approved { get; set; }
        public string AvgDuration { get; set; } = "—";
        public double AvgConfidence { get; set; }
    }
}
